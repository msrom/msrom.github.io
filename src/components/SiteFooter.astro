---
import type { Locale } from '../i18n';
import { t, ui } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="shell">
    <p>
      © {year} Manuel Suárez Román · {t(ui.sections.service, locale)}: reviewer, <em>Computers & Security</em>.
    </p>
  </div>
</footer>
